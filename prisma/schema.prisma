generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// CARDÁPIO / PRODUTOS
// =====================================================

model Category {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name              String
  slug              String
  description       String?
  type              CategoryType @default(NORMAL)
  selectionRequired Boolean      @default(false)
  active            Boolean      @default(true)
  sortOrder         Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  additionalLinks AdditionalCategory[]
  products        Product[]
  productLinks    ProductCategory[]

  @@unique([company_id, slug])
  @@index([company_id], map: "idx_category_company")
  @@index([branch_id], map: "idx_category_branch")
}

model Product {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid
  categoryId String

  name        String
  slug        String
  description String?
  price       Float
  imageUrl    String?
  active      Boolean @default(true)
  inStock     Boolean @default(true)
  required    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  comboGroupItems          ComboGroupItem[]
  orderItems               OrderItem[]
  productAdditionalConfigs ProductAdditional[]
  categories               ProductCategory[]

  @@unique([company_id, slug])
  @@index([company_id], map: "idx_product_company")
  @@index([branch_id], map: "idx_product_branch")
  @@index([categoryId], map: "idx_product_category")
}

model ProductCategory {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  productId   String
  categoryId  String
  sortOrder   Int      @default(0)
  customPrice Float?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "productcategory_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([company_id], map: "idx_productcategory_company")
  @@index([branch_id], map: "idx_productcategory_branch")
}

model Additional {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name        String
  slug        String
  description String?
  price       Float
  required    Boolean @default(false)
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  categoryLinks  AdditionalCategory[]
  productConfigs ProductAdditional[]

  @@unique([company_id, slug])
  @@index([company_id], map: "idx_additional_company")
  @@index([branch_id], map: "idx_additional_branch")
}

model AdditionalCategory {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  additionalId String
  categoryId   String
  createdAt    DateTime @default(now())

  companies  companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch     branches?  @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  additional Additional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([additionalId, categoryId])
  @@index([company_id], map: "idx_additionalcategory_company")
  @@index([branch_id], map: "idx_additionalcategory_branch")
}

model ProductAdditional {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  productId    String
  additionalId String
  required     Boolean  @default(false)
  createdAt    DateTime @default(now())

  companies  companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "productadditional_company_fk")
  branch     branches?  @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  additional Additional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, additionalId])
  @@index([company_id], map: "idx_productadditional_company")
  @@index([branch_id], map: "idx_productadditional_branch")
}

model Combo {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name        String
  slug        String
  description String?
  price       Float
  imageUrl    String?

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies    @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches?    @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  groups    ComboGroup[]

  @@unique([company_id, slug])
  @@index([company_id], map: "idx_combo_company")
  @@index([branch_id], map: "idx_combo_branch")
}

model ComboGroup {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  comboId   String
  name      String
  required  Boolean  @default(true)
  minSelect Int      @default(1)
  maxSelect Int      @default(1)
  createdAt DateTime @default(now())

  companies companies        @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches?        @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  combo     Combo            @relation(fields: [comboId], references: [id], onDelete: Cascade)
  items     ComboGroupItem[]

  @@index([company_id], map: "idx_combogroup_company")
  @@index([branch_id], map: "idx_combogroup_branch")
}

model ComboGroupItem {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  comboGroupId String
  productId    String
  createdAt    DateTime @default(now())

  companies  companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch     branches?  @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  comboGroup ComboGroup @relation(fields: [comboGroupId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comboGroupId, productId])
  @@index([company_id], map: "idx_combogroupitem_company")
  @@index([branch_id], map: "idx_combogroupitem_branch")
}

// =====================================================
// CLIENTES / PEDIDOS / ENTREGA
// =====================================================

model Customer {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name         String
  whatsapp     String
  email        String?
  cep          String?
  address      String?
  neighborhood String?
  city         String?
  cpf          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  orders    Order[]

  @@unique([company_id, whatsapp])
  @@index([company_id], map: "idx_customer_company")
  @@index([branch_id], map: "idx_customer_branch")
  @@index([whatsapp], map: "idx_customer_whatsapp")
}

model Driver {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  whatsapp  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  companies companies       @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "driver_company_fk")
  branch    branches?       @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  batches   DeliveryBatch[]
  orders    Order[]

  @@index([company_id], map: "idx_driver_company")
  @@index([branch_id], map: "idx_driver_branch")
}

model DeliveryBatch {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  code      String
  driverId  String
  routeMode RouteMode
  status    DeliveryBatchStatus @default(MONTADO)
  createdAt DateTime            @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "deliverybatch_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  driver    Driver    @relation(fields: [driverId], references: [id])
  orders    Order[]

  @@unique([company_id, code])
  @@index([company_id], map: "idx_deliverybatch_company")
  @@index([branch_id], map: "idx_deliverybatch_branch")
}

model Order {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  code          String?
  status        OrderStatus   @default(NOVO)
  paymentMethod PaymentMethod @default(PIX)
  total         Float         @default(0)

  customerId      String?
  driverId        String?
  deliveryBatchId String?

  archived   Boolean   @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  companies     companies      @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_company_fk")
  branch        branches?      @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  customer      Customer?      @relation(fields: [customerId], references: [id])
  deliveryBatch DeliveryBatch? @relation(fields: [deliveryBatchId], references: [id])
  driver        Driver?        @relation(fields: [driverId], references: [id])
  items         OrderItem[]

  @@unique([company_id, code])
  @@index([company_id], map: "idx_order_company")
  @@index([branch_id], map: "idx_order_branch")
  @@index([customerId], map: "idx_order_customer")
  @@index([status], map: "idx_order_status")
  @@index([archived], map: "idx_order_archived")
}

model OrderItem {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  orderId   String
  productId String?
  name      String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orderitem_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  order     Order     @relation(fields: [orderId], references: [id])
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([company_id], map: "idx_orderitem_company")
  @@index([branch_id], map: "idx_orderitem_branch")
  @@index([orderId], map: "idx_orderitem_order")
}

// =====================================================
// CRM / WHATSAPP / AUTOMAÇÕES
// =====================================================

model CrmCustomer {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name  String?
  phone String
  email String?
  tags  String[]
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies    @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches?    @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  messages  CrmMessage[]

  @@unique([company_id, phone])
  @@index([company_id], map: "idx_crmcustomer_company")
  @@index([branch_id], map: "idx_crmcustomer_branch")
  @@index([phone], map: "idx_crmcustomer_phone")
}

model CrmMessage {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  customerId String?
  phone      String
  direction  String
  source     String   @default("whatsapp")
  message    String
  createdAt  DateTime @default(now())

  companies companies    @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches?    @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  customer  CrmCustomer? @relation(fields: [customerId], references: [id])

  @@index([company_id], map: "idx_crmmessage_company")
  @@index([branch_id], map: "idx_crmmessage_branch")
  @@index([customerId], map: "idx_crmmessage_customer")
  @@index([phone], map: "idx_crmmessage_phone")
}

model WhatsappSession {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  sessionId String
  status    String   @default("offline")
  qr        String?
  createdAt DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "whatsappsession_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([company_id, sessionId])
  @@index([company_id], map: "idx_whatsappsession_company")
  @@index([branch_id], map: "idx_whatsappsession_branch")
}

model Campaign {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  message   String
  status    String   @default("draft")
  createdAt DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([company_id], map: "idx_campaign_company")
  @@index([branch_id], map: "idx_campaign_branch")
}

model Automation {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  trigger   String
  response  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([company_id], map: "idx_automation_company")
  @@index([branch_id], map: "idx_automation_branch")
}

model leads {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name               String?
  phone              String?
  email              String?
  status             String?   @default("novo")
  session_id         Int?      @default(1)
  ai_paused          Boolean?  @default(false)
  conversation_stage String?   @default("new")
  last_message       String?
  last_message_at    DateTime? @db.Timestamptz(6)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  whatsapp_lid       String?
  remote_jid         String?
  opening_sent       Boolean?  @default(false)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  campaign_step      Int?      @default(0)
  last_campaign_at   DateTime? @db.Timestamptz(6)
  reactivation_at    DateTime? @db.Timestamptz(6)
  opt_out            Boolean?  @default(false)

  companies        companies          @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch           branches?          @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  automation_queue automation_queue[]
  messages         messages[]

  @@unique([company_id, phone])
  @@index([company_id], map: "idx_leads_company")
  @@index([branch_id], map: "idx_leads_branch")
  @@index([phone], map: "idx_leads_phone")
  @@index([remote_jid], map: "idx_leads_remote_jid")
}

model messages {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  lead_id    String?   @db.Uuid
  direction  String?
  content    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  leads     leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_messages_company")
  @@index([branch_id], map: "idx_messages_branch")
  @@index([lead_id], map: "idx_messages_lead")
  @@index([created_at], map: "idx_messages_created_at")
}

model automation_queue {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  lead_id      String?   @db.Uuid
  phone        String?
  session_id   Int?      @default(1)
  type         String?
  status       String?   @default("pending")
  scheduled_at DateTime? @default(now()) @db.Timestamptz(6)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  sent_at      DateTime? @db.Timestamptz(6)
  error        String?
  message      String?
  campaign_id  String?   @db.Uuid
  attempts     Int?      @default(0)

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  leads     leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_automation_queue_company")
  @@index([branch_id], map: "idx_automation_queue_branch")
  @@index([lead_id], map: "idx_automation_queue_lead")
  @@index([status], map: "idx_automation_queue_status")
  @@index([scheduled_at], map: "idx_automation_queue_scheduled_at")
}

model promotion_campaigns {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name              String?
  message           String
  whatsapp_accounts Json?     @default("[]")
  target_days       Int?      @default(1)
  total_queued      Int?      @default(0)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([company_id], map: "idx_promotion_campaigns_company")
  @@index([branch_id], map: "idx_promotion_campaigns_branch")
}

// =====================================================
// RADAR LOCAL / PROSPECTS
// =====================================================

model Prospect {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  age       Int?
  email     String?
  phone1    String?
  phone2    String?
  gender    String?
  city      String?
  address   String?
  cep       String?
  latitude  Float?
  longitude Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies        @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prospect_company_fk")
  branch    branches?        @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  exports   ProspectExport[]

  @@index([email])
  @@index([phone1])
  @@index([phone2])
  @@index([city])
  @@index([cep])
  @@index([latitude, longitude])
  @@index([company_id], map: "idx_prospect_company")
  @@index([branch_id], map: "idx_prospect_branch")
}

model ProspectExport {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  prospectId String
  clientId   String
  action     String
  createdAt  DateTime @default(now())

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prospectexport_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  prospect  Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([prospectId, clientId])
  @@index([clientId])
  @@index([createdAt])
  @@index([company_id], map: "idx_prospectexport_company")
  @@index([branch_id], map: "idx_prospectexport_branch")
}

model ProspectImportJob {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  fileName     String?
  totalRows    Int      @default(0)
  created      Int      @default(0)
  updated      Int      @default(0)
  duplicated   Int      @default(0)
  invalidPhone Int      @default(0)
  underAge     Int      @default(0)
  status       String   @default("PENDING")
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prospectimportjob_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([company_id], map: "idx_prospectimportjob_company")
  @@index([branch_id], map: "idx_prospectimportjob_branch")
}

model ProspectUsage {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  clientId     String
  month        String
  monthlyLimit Int      @default(500)
  used         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prospectusage_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([company_id, clientId, month])
  @@index([clientId])
  @@index([company_id], map: "idx_prospectusage_company")
  @@index([branch_id], map: "idx_prospectusage_branch")
}

// =====================================================
// SAAS / EMPRESAS / PLANOS / PERMISSÕES
// =====================================================

model companies {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String    @unique
  logo_url       String?
  active         Boolean   @default(true)
  trial_ends_at  DateTime? @db.Timestamptz(6)
  plan_id        String?   @db.Uuid
