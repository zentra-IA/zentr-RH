// =====================================================
// RH / RECRUTAMENTO E SELEÇÃO - ZENTRA RH
// =====================================================

model Job {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  title       String
  description String?
  department  String?

  city         String?
  state        String?
  neighborhood String?
  region       String?
  zipCode      String?

  workMode     String? // presencial | remoto | hibrido
  contractType String? // clt | pj | estagio | temporario
  salaryMin    Float?
  salaryMax    Float?

  educationRequired  String?
  experienceRequired String?
  skillsRequired     String[] @default([])
  languagesRequired  String[] @default([])

  status String @default("open") // open | draft | paused | closed | archived

  requirements Json?
  filters      Json?
  aiCriteria   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "job_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  questions       JobQuestion[]
  matches         JobMatch[]
  applications    JobApplication[]
  interviews      Interview[]
  hiringProcesses HiringProcess[]

  @@index([company_id], map: "idx_job_company")
  @@index([branch_id], map: "idx_job_branch")
  @@index([status], map: "idx_job_status")
  @@index([city], map: "idx_job_city")
  @@index([state], map: "idx_job_state")
  @@index([region], map: "idx_job_region")
  @@index([zipCode], map: "idx_job_zip_code")
}

model CandidateProfile {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  name      String
  firstName String?
  lastName  String?
  cpf       String?
  rg        String?
  birthDate DateTime? @db.Date
  gender    String?

  phone  String?
  mobile String?
  email  String?

  city         String?
  state        String?
  neighborhood String?
  region       String?
  zipCode      String?
  address      String?

  education    String?
  course       String?
  courseStatus String?
  institution  String?

  lastRole              String?
  experiences           Json?
  totalExperienceMonths Int?
  professionalSummary   String?

  skills    String[] @default([])
  languages String[] @default([])

  salaryExpectation Decimal? @db.Decimal(10, 2)

  resumeOrigin  String?
  resumeFileUrl String?
  rawImportData Json?

  aiSummary       String?
  aiExtractedData Json?

  status String  @default("talent_pool") // new | screening | interview | approved | hired | rejected | talent_pool
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidateprofile_company_fk")
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  answers         CandidateQuestionAnswer[]
  matches         JobMatch[]
  applications    JobApplication[]
  interviews      Interview[]
  hiringProcesses HiringProcess[]

  @@unique([company_id, cpf])
  @@index([company_id], map: "idx_candidateprofile_company")
  @@index([branch_id], map: "idx_candidateprofile_branch")
  @@index([phone], map: "idx_candidateprofile_phone")
  @@index([mobile], map: "idx_candidateprofile_mobile")
  @@index([email], map: "idx_candidateprofile_email")
  @@index([city], map: "idx_candidateprofile_city")
  @@index([state], map: "idx_candidateprofile_state")
  @@index([region], map: "idx_candidateprofile_region")
  @@index([zipCode], map: "idx_candidateprofile_zip_code")
  @@index([education], map: "idx_candidateprofile_education")
  @@index([resumeOrigin], map: "idx_candidateprofile_origin")
  @@index([status], map: "idx_candidateprofile_status")
}

model JobApplication {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  jobId       String
  candidateId String

  source          String?
  applicationDate DateTime? @default(now())
  stage           String    @default("triagem") // triagem | entrevista | aprovado | reprovado | contratado
  status          String    @default("active")
  history         Json?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies        @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobapplication_company_fk")
  branch    branches?        @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([company_id], map: "idx_jobapplication_company")
  @@index([branch_id], map: "idx_jobapplication_branch")
  @@index([jobId], map: "idx_jobapplication_job")
  @@index([candidateId], map: "idx_jobapplication_candidate")
  @@index([stage], map: "idx_jobapplication_stage")
  @@index([status], map: "idx_jobapplication_status")
}

model JobQuestion {
  id        String   @id @default(cuid())
  jobId     String
  question  String
  type      String   @default("text") // text | textarea | select | boolean | number
  options   Json?
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job     Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  answers CandidateQuestionAnswer[]

  @@index([jobId], map: "idx_jobquestion_job")
}

model CandidateQuestionAnswer {
  id          String   @id @default(cuid())
  candidateId String
  questionId  String
  answer      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  question  JobQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([candidateId, questionId])
  @@index([candidateId], map: "idx_candidateanswer_candidate")
  @@index([questionId], map: "idx_candidateanswer_question")
}

model JobMatch {
  id          String @id @default(cuid())
  jobId       String
  candidateId String

  score               Int
  strengths           Json?
  attentionPoints     Json?
  missingRequirements Json?
  reason              String?
  aiRawResult         Json?

  status    String   @default("suggested") // suggested | selected | rejected | contacted | interview | hired
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId], map: "idx_jobmatch_job")
  @@index([candidateId], map: "idx_jobmatch_candidate")
  @@index([score], map: "idx_jobmatch_score")
  @@index([status], map: "idx_jobmatch_status")
}

model Interview {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  jobId       String
  candidateId String

  scheduledAt DateTime
  durationMin Int      @default(30)
  interviewer String?
  meetingUrl  String?
  location    String?
  status      String   @default("scheduled") // scheduled | confirmed | done | canceled | no_show | approved | rejected
  score       Int?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies        @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "interview_company_fk")
  branch    branches?        @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([company_id], map: "idx_interview_company")
  @@index([branch_id], map: "idx_interview_branch")
  @@index([jobId], map: "idx_interview_job")
  @@index([candidateId], map: "idx_interview_candidate")
  @@index([scheduledAt], map: "idx_interview_scheduled_at")
  @@index([status], map: "idx_interview_status")
}

model HiringProcess {
  id         String  @id @default(cuid())
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  candidateId String
  jobId       String?

  position     String?
  salary       Decimal?  @db.Decimal(10, 2)
  contractType String?
  status       String    @default("pending_documents") // pending_documents | exams | contract | hired | canceled
  startDate    DateTime? @db.Date
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies companies        @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "hiringprocess_company_fk")
  branch    branches?        @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)

  documents CandidateDocument[]

  @@index([company_id], map: "idx_hiringprocess_company")
  @@index([branch_id], map: "idx_hiringprocess_branch")
  @@index([candidateId], map: "idx_hiringprocess_candidate")
  @@index([jobId], map: "idx_hiringprocess_job")
  @@index([status], map: "idx_hiringprocess_status")
}

model CandidateDocument {
  id              String @id @default(cuid())
  hiringProcessId String

  type    String
  fileUrl String?
  status  String  @default("pending") // pending | received | approved | rejected
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hiringProcess HiringProcess @relation(fields: [hiringProcessId], references: [id], onDelete: Cascade)

  @@index([hiringProcessId], map: "idx_candidatedocument_hiring")
  @@index([status], map: "idx_candidatedocument_status")
}

// =====================================================
// ENUMS
// =====================================================

enum CategoryType {
  NORMAL
  PIZZA_HALF_HALF
}

enum OrderStatus {
  NOVO
  EM_PREPARO
  SAIU_PARA_ENTREGA
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  PIX
  DINHEIRO
  DEBITO
  CREDITO
}

enum DeliveryBatchStatus {
  MONTADO
  ENVIADO
  EM_ROTA
  FINALIZADO
}

enum RouteMode {
  NEAR_TO_FAR
  FAR_TO_NEAR
}
