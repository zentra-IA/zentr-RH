model company_contacts {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid
  branch_id  String? @db.Uuid

  restaurant_name  String?
  company_name     String?
  owner_name       String?
  responsible_name String?

  document String?
  cnpj     String?
  cpf      String?

  email         String?
  phone         String?
  whatsapp      String?
  extra_contact String?

  address String?
  city    String?
  state   String?
  cep     String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  companies companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches? @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([company_id], map: "idx_company_contacts_company_id")
  @@index([branch_id], map: "idx_company_contacts_branch_id")
}

model message_templates {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String? @db.Uuid
  branch_id  String? @db.Uuid

  name     String?
  title    String?
  type     String? @default("default")
  category String?

  intent        String?
  trigger       String?
  trigger_words String[] @default([])

  content       String?
  message       String?
  base_message  String?
  final_message String?
  response      String?

  variables Json? @default("{}")
  metadata  Json? @default("{}")

  active     Boolean @default(true)
  sort_order Int     @default(0)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  companies  companies?           @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch     branches?            @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  variations message_variations[]

  @@index([company_id], map: "idx_message_templates_company_id")
  @@index([branch_id], map: "idx_message_templates_branch_id")
  @@index([intent], map: "idx_message_templates_intent")
}

model message_variations {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String? @db.Uuid
  branch_id   String? @db.Uuid
  template_id String? @db.Uuid

  name     String?
  title    String?
  type     String? @default("default")
  category String?

  content       String?
  message       String?
  variation     String?
  base_message  String?
  final_message String?

  active     Boolean @default(true)
  sort_order Int     @default(0)
  metadata   Json?   @default("{}")

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  companies companies?         @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branch    branches?          @relation(fields: [branch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  template  message_templates? @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_message_variations_company_id")
  @@index([branch_id], map: "idx_message_variations_branch_id")
  @@index([template_id], map: "idx_message_variations_template_id")
}

model support_knowledge {
